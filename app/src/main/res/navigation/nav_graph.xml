<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/authFragment">

    <fragment
        android:id="@+id/authFragment"
        android:name="com.project.fridgemate.ui.auth.AuthFragment"
        android:label="AuthFragment"
        tools:layout="@layout/fragment_auth">
        <action
            android:id="@+id/action_authFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/authFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.project.fridgemate.ui.dashboard.DashboardFragment"
        android:label="DashboardFragment"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_authFragment"
            app:destination="@id/authFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_dashboardFragment_to_myProfileFragment"
            app:destination="@id/myProfileFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_recipeDetailFragment"
            app:destination="@id/recipeDetailFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_addPostFragment"
            app:destination="@id/addPostFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_mapViewFragment"
            app:destination="@id/mapViewFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_editPostFragment"
            app:destination="@id/editPostFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_myPostsFragment"
            app:destination="@id/myPostsFragment" />
    </fragment>
    <fragment
        android:id="@+id/myProfileFragment"
        android:name="com.project.fridgemate.ui.profile.MyProfileFragment"
        android:label="MyProfileFragment"
        tools:layout="@layout/fragment_my_profile">
    </fragment>
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.project.fridgemate.ui.settings.SettingsFragment"
        android:label="SettingsFragment"
        tools:layout="@layout/fragment_settings">
    </fragment>
    <fragment
        android:id="@+id/recipeDetailFragment"
        android:name="com.project.fridgemate.ui.recipes.RecipeDetailFragment"
        android:label="RecipeDetailFragment"
        tools:layout="@layout/fragment_recipe_detail">
        <argument
            android:name="recipeId"
            app:argType="long"
            android:defaultValue="0L" />
        <argument
            android:name="serverRecipeId"
            app:argType="string"
            android:defaultValue="" />
        <action
            android:id="@+id/action_recipeDetailFragment_to_addPostFragment"
            app:destination="@id/addPostFragment" />
    </fragment>
    <fragment
        android:id="@+id/addPostFragment"
        android:name="com.project.fridgemate.ui.feed.AddPostFragment"
        android:label="AddPostFragment"
        tools:layout="@layout/fragment_add_post">
        <argument
            android:name="prefillTitle"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="prefillDescription"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="prefillRecipeId"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="prefillRecipeName"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="prefillRecipeTime"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="prefillRecipeDifficulty"
            app:argType="string"
            android:defaultValue="" />
    </fragment>
    <fragment
        android:id="@+id/mapViewFragment"
        android:name="com.project.fridgemate.ui.feed.MapViewFragment"
        android:label="MapViewFragment"
        tools:layout="@layout/fragment_map_view">
        <action
            android:id="@+id/action_mapViewFragment_to_recipeDetailFragment"
            app:destination="@id/recipeDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/myPostsFragment"
        android:name="com.project.fridgemate.ui.feed.MyPostsFragment"
        android:label="MyPostsFragment"
        tools:layout="@layout/fragment_my_posts">
        <action
            android:id="@+id/action_myPostsFragment_to_editPostFragment"
            app:destination="@id/editPostFragment" />
        <action
            android:id="@+id/action_myPostsFragment_to_recipeDetailFragment"
            app:destination="@id/recipeDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/editPostFragment"
        android:name="com.project.fridgemate.ui.feed.EditPostFragment"
        android:label="EditPostFragment"
        tools:layout="@layout/fragment_edit_post">
        <argument
            android:name="postId"
            app:argType="string" />
        <argument
            android:name="postTitle"
            app:argType="string" />
        <argument
            android:name="postDescription"
            app:argType="string" />
        <argument
            android:name="postImageUrl"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="linkedRecipeName"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="linkedRecipeTime"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="linkedRecipeDifficulty"
            app:argType="string"
            android:defaultValue="" />
    </fragment>
</navigation>
