<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_popup_menu">

    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_step_number"
        android:backgroundTint="@color/divider_color" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/leave_fridge"
        android:textColor="@color/popup_text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/leave_fridge_confirmation"
        android:textColor="@color/gray_text"
        android:textSize="14sp"
        android:paddingBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmLeave"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="start|center_vertical"
        android:text="@string/leave"
        android:textColor="@color/popup_logout_text"
        android:textSize="16sp"
        app:icon="@drawable/ic_logout"
        app:iconPadding="16dp"
        app:iconTint="@color/popup_logout_text"
        app:rippleColor="#10D32F2F" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="start|center_vertical"
        android:text="@string/cancel"
        android:textColor="@color/popup_text"
        android:textSize="16sp"
        app:icon="@drawable/ic_close"
        app:iconPadding="16dp"
        app:iconTint="@color/popup_icon_tint"
        app:rippleColor="#10000000" />

</LinearLayout>